# ==================== LLM配置 ====================
# 默认LLM提供商: openrouter / openai / anthropic / qwen / deepseek / zhipu / ollama
LLM_PROVIDER=openrouter

# OpenRouter (聚合平台, 支持免费模型)
# 免费模型每天50次请求, 充值$10解锁1000次/天
# 注册: https://openrouter.ai/
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_MODEL=google/gemma-4-31b-it:free

# OpenAI
# OPENAI_API_KEY=your-openai-api-key-here
# OPENAI_MODEL=gpt-4

# Anthropic
# ANTHROPIC_API_KEY=your-anthropic-api-key-here
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# 通义千问 (Qwen)
# QWEN_API_KEY=your-qwen-api-key-here
# QWEN_MODEL=qwen-plus

# DeepSeek
# DEEPSEEK_API_KEY=your-deepseek-api-key-here
# DEEPSEEK_MODEL=deepseek-chat

# 智谱AI (GLM)
# ZHIPU_API_KEY=your-zhipu-api-key-here
# ZHIPU_MODEL=glm-4

# Ollama (本地模型, 无需API Key)
# OLLAMA_MODEL=qwen2.5:7b
# OLLAMA_BASE_URL=http://localhost:11434/v1

# ==================== 安全配置 ====================
# JWT签名密钥 (生产环境必须修改!)
JWT_SECRET=change-this-to-a-random-secret

# API访问密钥 (可选, 留空则不启用鉴权)
# ASTOCK_API_KEY=your-api-key-here

# ==================== 数据库配置 ====================
# SQLite数据库路径 (默认: data/astock.db)
# ASTOCK_DB_PATH=data/astock.db

# ==================== Web服务配置 ====================
# CORS允许的域名 (多个用逗号分隔)
# CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# 开发模式 (启用后跳过部分安全检查)
# ASTOCK_DEV_MODE=false

# ==================== 调度器配置 ====================
# 是否启用定时调度
# ASTOCK_SCHEDULER_ENABLED=false

# 通知级别: DEBUG / INFO / WARNING / ERROR
# ASTOCK_NOTIFY_LEVEL=WARNING
